    "./electron-updater/main": {
      "types": "./dist/electron-updater/main.d.ts",
      "import": "./dist/electron-updater/main.js"
    },
    "./electron-updater/preload": {
      "types": "./dist/electron-updater/preload.d.ts",
      "import": "./dist/electron-updater/preload.js"
    },
    "./electron-updater/builder": {
      "types": "./dist/electron-updater/builder.d.ts",
      "import": "./dist/electron-updater/builder.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "npm run typecheck",
    "prepack": "npm run clean",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "electron": ">=30",
    "electron-updater": ">=6",
    "iron-session": ">=8",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "electron-updater": {
      "optional": true
    },
    "iron-session": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.17",
    "iron-session": "^8.0.4",
    "react": "^19.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
