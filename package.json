    "./api-fetch/sveltekit": {
      "types": "./dist/api-fetch/sveltekit.d.ts",
      "import": "./dist/api-fetch/sveltekit.js"
    },
    "./http-response": {
      "types": "./dist/http-response/index.d.ts",
      "import": "./dist/http-response/index.js"
    },
    "./electron-log": {
      "types": "./dist/electron-log/index.d.ts",
      "import": "./dist/electron-log/index.js"
    },
    "./electron-log/main": {
      "types": "./dist/electron-log/main.d.ts",
      "import": "./dist/electron-log/main.js"
