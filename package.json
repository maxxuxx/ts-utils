{
  "name": "@maxxuxx/ts-utils",
  "version": "0.7.1",
  "description": "Shared TypeScript utilities",
  "type": "module",
  "license": "MIT",
  "author": "haru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxxuxx/ts-utils.git"
  },
  "homepage": "https://github.com/maxxuxx/ts-utils#readme",
  "bugs": {
    "url": "https://github.com/maxxuxx/ts-utils/issues"
  },
  "keywords": [
    "typescript",
    "utils",
    "zod",
    "parser",
    "validation"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/readme.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./is": {
      "types": "./dist/is/index.d.ts",
      "import": "./dist/is/index.js"
    },
    "./try-catch": {
      "types": "./dist/try-catch/index.d.ts",
      "import": "./dist/try-catch/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./normalize": {
      "types": "./dist/normalize/index.d.ts",
      "import": "./dist/normalize/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./time": {
      "types": "./dist/time/index.d.ts",
      "import": "./dist/time/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.js"
    },
    "./api-fetch": {
      "types": "./dist/api-fetch/index.d.ts",
      "import": "./dist/api-fetch/index.js"
    },
    "./electron-log": {
      "types": "./dist/electron-log/index.d.ts",
      "import": "./dist/electron-log/index.js"
    },
    "./electron-log/main": {
      "types": "./dist/electron-log/main.d.ts",
      "import": "./dist/electron-log/main.js"
    },
    "./electron-log/preload": {
      "types": "./dist/electron-log/preload.d.ts",
      "import": "./dist/electron-log/preload.js"
    },
    "./electron-log/renderer": {
      "types": "./dist/electron-log/renderer.d.ts",
      "import": "./dist/electron-log/renderer.js"
    },
    "./electron-updater": {
      "types": "./dist/electron-updater/index.d.ts",
      "import": "./dist/electron-updater/index.js"
    },
    "./electron-updater/main": {
      "types": "./dist/electron-updater/main.d.ts",
      "import": "./dist/electron-updater/main.js"
    },
    "./electron-updater/preload": {
      "types": "./dist/electron-updater/preload.d.ts",
      "import": "./dist/electron-updater/preload.js"
    },
    "./electron-updater/builder": {
      "types": "./dist/electron-updater/builder.d.ts",
      "import": "./dist/electron-updater/builder.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "npm run typecheck",
    "prepack": "npm run clean",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "electron": ">=30",
    "electron-updater": ">=6"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "electron-updater": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
