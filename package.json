{
  "name": "@maxxuxx/ts-utils",
  "version": "0.7.17",
  "description": "Shared TypeScript utilities",
  "type": "module",
  "license": "MIT",
  "author": "haru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxxuxx/ts-utils.git"
  },
  "homepage": "https://github.com/maxxuxx/ts-utils#readme",
  "bugs": {
    "url": "https://github.com/maxxuxx/ts-utils/issues"
  },
  "keywords": [
    "typescript",
    "utils",
    "zod",
    "parser",
    "validation"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "src/**/readme.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./is": {
      "types": "./dist/is/index.d.ts",
      "import": "./dist/is/index.js"
    },
    "./try-catch": {
      "types": "./dist/try-catch/index.d.ts",
      "import": "./dist/try-catch/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./normalize": {
      "types": "./dist/normalize/index.d.ts",
      "import": "./dist/normalize/index.js"
    },
    "./object": {
      "types": "./dist/object/index.d.ts",
      "import": "./dist/object/index.js"
    },
    "./url": {
      "types": "./dist/url/index.d.ts",
      "import": "./dist/url/index.js"
    },
    "./promise": {
      "types": "./dist/promise/index.d.ts",
      "import": "./dist/promise/index.js"
    },
    "./json": {
      "types": "./dist/json/index.d.ts",
      "import": "./dist/json/index.js"
    },
    "./encoding": {
      "types": "./dist/encoding/index.d.ts",
      "import": "./dist/encoding/index.js"
    },
    "./jwt": {
      "types": "./dist/jwt/index.d.ts",
      "import": "./dist/jwt/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./time": {
      "types": "./dist/time/index.d.ts",
      "import": "./dist/time/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js"
